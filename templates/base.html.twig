<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#3076e0">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>
    {% block meta %}{% endblock %}
    <script>
        (function () {
            var storageKey = 'theme';
            var stored = localStorage.getItem(storageKey);
            var theme = stored === 'light' || stored === 'dark'
                ? stored
                : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
            var metaThemeColor = document.querySelector('meta[name="theme-color"]');
            if (metaThemeColor) {
                metaThemeColor.setAttribute('content', theme === 'dark' ? '#171933' : '#3076e0');
            }
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="ds-public min-h-screen flex flex-col {% block body_class %}{% endblock %}">
    <a href="#main" class="ds-skip-link">Aller au contenu principal</a>

    {% block layout %}
        {% include 'partials/public/header.html.twig' %}
        <main id="main" class="flex-1">
            {% include 'components/flash_messages.html.twig' with { mode: 'inline' } %}
            {% block main %}{% endblock %}
        </main>
        {% include 'partials/public/footer.html.twig' %}
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
