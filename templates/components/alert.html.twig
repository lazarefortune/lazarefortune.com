{#
    Props:
    - message (required)
    - title (optional)
    - variant: info|success|warning|danger (default: info)
    - class (extra classes)
#}
{% set variant = variant|default('info') %}
{% set extra_class = class|default('') %}

{% set variant_icons = {
    'info': 'info',
    'success': 'check-circle',
    'warning': 'alert-triangle',
    'danger': 'alert-circle',
} %}

{% set role = variant == 'danger' ? 'alert' : 'status' %}

<div class="ds-alert ds-alert-{{ variant }} {{ extra_class }}" role="{{ role }}">
    <span class="mt-0.5 shrink-0">
        {% include 'components/icon.html.twig' with { name: variant_icons[variant], size: 18 } %}
    </span>
    <div>
        {% if title is defined and title %}
            <p class="mb-1 font-medium">{{ title }}</p>
        {% endif %}
        <p>{{ message }}</p>
    </div>
</div>
