{#
    Props:
    - title (optional)
    - footer (optional)
    - class (extra classes)
    - content (optional string, use block card_body if embedding)
#}
{% set extra_class = class|default('') %}

<article class="ds-card {{ extra_class }}">
    {% if title is defined and title %}
        <header class="border-b border-slate-100 px-5 py-4">
            <h3 class="text-base font-semibold text-slate-900">{{ title }}</h3>
        </header>
    {% endif %}

    <div class="px-5 py-4 text-sm text-slate-600">
        {% if content is defined %}
            {{ content }}
        {% else %}
            {% block card_body %}{% endblock %}
        {% endif %}
    </div>

    {% if footer is defined and footer %}
        <footer class="border-t border-slate-100 px-5 py-3 text-sm text-slate-500">
            {{ footer }}
        </footer>
    {% endif %}
</article>
