{#
    Props:
    - title (optional)
    - footer (optional)
    - class (extra classes)
    - content (optional string, use block card_body if embedding)
#}
{% set extra_class = class|default('') %}

<article class="ds-card {{ extra_class }}">
    {% if title is defined and title %}
        <header class="ds-card-header px-5 py-4">
            <h3 class="text-base font-semibold">{{ title }}</h3>
        </header>
    {% endif %}

    <div class="px-5 py-4 text-base ds-text-muted">
        {% if content is defined %}
            {{ content }}
        {% else %}
            {% block card_body %}{% endblock %}
        {% endif %}
    </div>

    {% if footer is defined and footer %}
        <footer class="ds-card-footer px-5 py-3">
            {{ footer }}
        </footer>
    {% endif %}
</article>
