{#
    Props:
    - title (required)
    - description (optional)
    - action_label (optional)
    - action_href (optional)
    - icon (optional Lucide icon name, default: inbox)
#}
{% set icon_name = icon|default('inbox') %}

<div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white px-6 py-12 text-center">
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-primary-50 text-primary-600" aria-hidden="true">
        {% include 'components/icon.html.twig' with { name: icon_name, size: 24 } %}
    </div>
    <h2 class="ds-heading text-lg font-semibold text-slate-900">{{ title }}</h2>
    {% if description is defined and description %}
        <p class="mt-2 max-w-md text-sm text-slate-600">{{ description }}</p>
    {% endif %}
    {% if action_label is defined and action_href is defined %}
        <div class="mt-6">
            {% include 'components/button.html.twig' with { label: action_label, href: action_href, variant: 'primary', icon: 'plus' } %}
        </div>
    {% endif %}
</div>
