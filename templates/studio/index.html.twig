{% extends 'studio/layout.html.twig' %}

{% block title %}Studio - lazarefortune.com{% endblock %}

{% block studio_title %}Accueil Studio{% endblock %}

{% block studio_main %}
    {% include 'components/page_header.html.twig' with {
        eyebrow: 'Studio V3',
        title: 'Espace créateur',
        description: 'Gérez vos contenus pédagogiques depuis le Studio. Les modules interactifs React seront montés ici progressivement.',
    } %}

    {% include 'components/card.html.twig' with {
        title: 'Prochaines étapes',
        content: 'Video, playlists et publication seront ajoutés après validation du socle UI et Auth.',
        footer: 'Consultez le design system pour prévisualiser les composants.',
    } %}

    <div class="mt-4">
        {% include 'components/button.html.twig' with {
            label: 'Voir le design system',
            href: path('app_design_system'),
            variant: 'primary',
        } %}
    </div>

    <div class="mt-8" data-studio-app data-studio-page="home"></div>
{% endblock %}

{% block studio_javascripts %}
    {{ encore_entry_script_tags('studio') }}
{% endblock %}
