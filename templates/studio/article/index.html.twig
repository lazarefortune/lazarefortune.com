{% extends 'studio/layout.html.twig' %}

{% block title %}Articles - Studio{% endblock %}

{% block studio_title %}Articles{% endblock %}

{% block studio_main %}
    {% embed 'components/page_header.html.twig' with {
        eyebrow: 'Studio',
        title: 'Articles',
        description: 'Gérez vos articles. L’éditeur complet sera ajouté ultérieurement.',
    } %}
        {% block page_header_actions %}
            {% include 'components/button.html.twig' with {
                label: 'Créer',
                href: '#',
                variant: 'primary',
                icon: 'plus',
            } %}
        {% endblock %}
    {% endembed %}

    {% if articles is empty %}
        {% include 'components/empty_state.html.twig' with {
            title: 'Aucun article',
            description: 'Rédigez votre premier article pédagogique.',
            action_label: 'Créer un article',
            action_href: '#',
            icon: 'file-text',
        } %}
    {% else %}
        {% include 'studio/partials/index_list.html.twig' with { items: articles } %}
    {% endif %}
{% endblock %}
