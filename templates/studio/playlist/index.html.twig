{% extends 'studio/layout.html.twig' %}

{% block title %}Playlists - Studio{% endblock %}

{% block studio_title %}Playlists{% endblock %}

{% block studio_main %}
    {% embed 'components/page_header.html.twig' with {
        eyebrow: 'Studio',
        title: 'Playlists',
        description: 'Organisez vos contenus en parcours structurés par chapitres.',
    } %}
        {% block page_header_actions %}
            {% include 'components/button.html.twig' with {
                label: 'Créer',
                href: '#',
                variant: 'primary',
                icon: 'plus',
            } %}
        {% endblock %}
    {% endembed %}

    {% if playlists is empty %}
        {% include 'components/empty_state.html.twig' with {
            title: 'Aucune playlist',
            description: 'Créez votre première playlist pour regrouper vos contenus.',
            action_label: 'Créer une playlist',
            action_href: '#',
            icon: 'list-video',
        } %}
    {% else %}
        {% include 'studio/partials/index_list.html.twig' with { items: playlists } %}
    {% endif %}
{% endblock %}
