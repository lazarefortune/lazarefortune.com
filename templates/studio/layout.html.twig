{% extends 'base.html.twig' %}

{% block body_class %}ds-studio-body{% endblock %}

{% block layout %}
    {% set current_route = app.request.attributes.get('_route') %}
    {% set nav_items = [
        { route: 'studio_home', label: 'Accueil', icon: 'home', active: current_route == 'studio_home' },
        { route: 'studio_video_index', label: 'Vidéos', icon: 'video', active: current_route starts with 'studio_video_' },
        { route: 'studio_article_index', label: 'Articles', icon: 'file-text', active: current_route starts with 'studio_article_' },
        { route: 'studio_playlist_index', label: 'Playlists', icon: 'list-video', active: current_route starts with 'studio_playlist_' },
        { route: 'app_design_system', label: 'Design system', icon: 'palette', active: current_route == 'app_design_system' },
    ] %}

    <div class="ds-studio ds-studio-shell" data-studio-shell>
        {% include 'components/flash_messages.html.twig' with { mode: 'floating' } %}

        <aside class="ds-studio-sidebar" data-studio-sidebar aria-label="Navigation Studio">
            <div class="ds-studio-sidebar__header">
                <a href="{{ path('studio_home') }}" class="ds-studio-sidebar__brand font-space-grotesk">
                    <span class="ds-studio-sidebar__logo" aria-hidden="true">LF</span>
                    <span class="ds-studio-sidebar__brand-label">Studio</span>
                </a>
            </div>

            <nav class="ds-studio-sidebar__nav" aria-label="Sections Studio">
                {% include 'studio/partials/nav_links.html.twig' %}
            </nav>

            <div class="ds-studio-sidebar__footer">
                {% include 'studio/partials/user_menu.html.twig' %}
            </div>
        </aside>

        <div
            data-studio-mobile-overlay
            class="ds-studio-overlay hidden lg:hidden"
            aria-hidden="true"
        ></div>

        <aside
            data-studio-mobile-drawer
            id="studio-mobile-drawer"
            class="ds-studio-mobile-drawer"
            aria-hidden="true"
            aria-label="Menu Studio"
        >
            <div class="ds-studio-sidebar__header">
                <a href="{{ path('studio_home') }}" class="ds-studio-sidebar__brand">
                    <span class="ds-studio-sidebar__logo" aria-hidden="true">LF</span>
                    <span class="ds-studio-sidebar__brand-label">Studio</span>
                </a>
                <button
                    type="button"
                    data-studio-menu-close
                    class="ds-icon-link min-h-11 min-w-11"
                    aria-label="Fermer le menu Studio"
                >
                    {% include 'components/icon.html.twig' with { name: 'x', size: 20 } %}
                </button>
            </div>

            <nav class="ds-studio-sidebar__nav" aria-label="Sections Studio">
                {% include 'studio/partials/nav_links.html.twig' with { close_on_navigate: true } %}
            </nav>

            <div class="ds-studio-sidebar__footer">
                {% include 'studio/partials/user_menu.html.twig' %}
            </div>
        </aside>

        <div class="ds-studio-main-wrapper" data-studio-content>
            <header class="ds-studio-topbar" data-studio-topbar>
                <div class="ds-studio-topbar__container">
                    <div class="ds-studio-topbar__start">
                        <button
                            type="button"
                            data-studio-menu-toggle
                            class="ds-studio-topbar__menu-btn lg:hidden"
                            aria-expanded="false"
                            aria-controls="studio-mobile-drawer"
                            aria-label="Ouvrir le menu Studio"
                            data-testid="studio-menu-toggle"
                        >
                            {% include 'components/icon.html.twig' with { name: 'menu', size: 24 } %}
                        </button>
                    </div>

                    <div class="ds-studio-topbar__actions">
                        {% include 'components/theme_toggle.html.twig' %}
                        {% include 'studio/partials/header_user_menu.html.twig' %}
                    </div>
                </div>
            </header>

            <main id="main" class="ds-studio-main">
                <div class="ds-studio-main__inner">
                    {% include 'studio/partials/breadcrumb.html.twig' %}
                    {% block studio_main %}{% endblock %}
                </div>
            </main>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% block studio_javascripts %}{% endblock %}
{% endblock %}
