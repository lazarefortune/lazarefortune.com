{% extends 'studio/layout.html.twig' %}

{% set page_title = video.title is not empty ? video.title : 'Vidéo sans titre' %}

{% block title %}{{ page_title }} - Studio{% endblock %}

{% block studio_title %}{{ page_title }}{% endblock %}

{% block studio_main %}
    {% embed 'components/page_header.html.twig' with {
        eyebrow: 'Studio',
        title: page_title,
        description: 'Gérez le contenu, la source, le classement et la publication de cette vidéo.',
    } %}
        {% block page_header_actions %}
            {% include 'studio/partials/publish_action_bar.html.twig' with {
                status: video.status,
                publicationActions: publicationActions,
                content_form_id: 'studio-video-content-form',
                testid: 'studio-video-publish-action-bar',
            } %}
        {% endblock %}
    {% endembed %}

    {% include 'studio/partials/video_publication_forms.html.twig' with { video: video } %}

    <div class="ds-card ds-studio overflow-hidden" data-studio-video-edit data-testid="studio-video-edit-page">
        <div data-studio-video-tabs data-testid="studio-video-edit-tabs">
            <div
                class="ds-tabs__list"
                role="tablist"
                aria-label="Sections d edition de la video"
            >
                <a
                    href="#content"
                    id="tab-content"
                    class="ds-tabs__tab"
                    role="tab"
                    aria-controls="panel-content"
                    data-studio-tab="content"
                    data-testid="studio-video-tab-content"
                >Contenu</a>
                <a
                    href="#source"
                    id="tab-source"
                    class="ds-tabs__tab"
                    role="tab"
                    aria-controls="panel-source"
                    data-studio-tab="source"
                    data-testid="studio-video-tab-source"
                >Source vidéo</a>
                <a
                    href="#classification"
                    id="tab-classification"
                    class="ds-tabs__tab"
                    role="tab"
                    aria-controls="panel-classification"
                    data-studio-tab="classification"
                    data-testid="studio-video-tab-classification"
                >Classement</a>
                <a
                    href="#publication"
                    id="tab-publication"
                    class="ds-tabs__tab"
                    role="tab"
                    aria-controls="panel-publication"
                    data-studio-tab="publication"
                    data-testid="studio-video-tab-publication"
                >Publication</a>
            </div>

            <div class="ds-tabs__panels px-5 py-5 sm:px-6">
                <section
                    id="panel-content"
                    class="ds-tabs__panel"
                    role="tabpanel"
                    aria-labelledby="tab-content"
                    data-studio-tab-panel="content"
                    data-testid="studio-video-panel-content"
                >
                    {{ form_start(contentForm, {
                        attr: {
                            id: 'studio-video-content-form',
                            class: 'flex flex-col gap-5',
                            'data-testid': 'studio-video-content-form',
                        },
                    }) }}
                        <div class="grid gap-5">
                            <div class="flex flex-col gap-1.5">
                                {{ form_label(contentForm.title, null, { label_attr: { class: 'ds-label' } }) }}
                                {{ form_widget(contentForm.title) }}
                                {{ form_errors(contentForm.title) }}
                            </div>

                            <div class="flex flex-col gap-1.5">
                                {{ form_label(contentForm.slug, null, { label_attr: { class: 'ds-label' } }) }}
                                {{ form_widget(contentForm.slug) }}
                                {% if contentForm.slug.vars.help is defined and contentForm.slug.vars.help %}
                                    <p class="ds-form-help">{{ contentForm.slug.vars.help }}</p>
                                {% endif %}
                                {{ form_errors(contentForm.slug) }}
                            </div>

                            <div class="flex flex-col gap-1.5">
                                {{ form_label(contentForm.excerpt, null, { label_attr: { class: 'ds-label' } }) }}
                                {{ form_widget(contentForm.excerpt) }}
                                {{ form_errors(contentForm.excerpt) }}
                            </div>

                            <div class="flex flex-col gap-1.5">
                                {{ form_label(contentForm.description, null, { label_attr: { class: 'ds-label' } }) }}
                                {{ form_widget(contentForm.description) }}
                                {{ form_errors(contentForm.description) }}
                            </div>

                            <div class="grid gap-5 sm:grid-cols-2">
                                <div class="flex flex-col gap-1.5">
                                    {{ form_label(contentForm.level, null, { label_attr: { class: 'ds-label' } }) }}
                                    {{ form_widget(contentForm.level) }}
                                    {{ form_errors(contentForm.level) }}
                                </div>

                                <div class="flex flex-col gap-1.5">
                                    {{ form_label(contentForm.coverImagePath, null, { label_attr: { class: 'ds-label' } }) }}
                                    {{ form_widget(contentForm.coverImagePath) }}
                                    {% if contentForm.coverImagePath.vars.help is defined and contentForm.coverImagePath.vars.help %}
                                        <p class="ds-form-help">{{ contentForm.coverImagePath.vars.help }}</p>
                                    {% endif %}
                                    {{ form_errors(contentForm.coverImagePath) }}
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col gap-3 ds-border-t pt-5 sm:flex-row sm:items-center sm:justify-end">
                            {% include 'components/button.html.twig' with {
                                label: 'Enregistrer',
                                type: 'submit',
                                variant: 'primary',
                                icon: 'save',
                                attrs: {
                                    'data-testid': 'studio-video-save-inline',
                                },
                            } %}
                        </div>
                    {{ form_end(contentForm) }}
                </section>

                <section
                    id="panel-source"
                    class="ds-tabs__panel"
                    role="tabpanel"
                    aria-labelledby="tab-source"
                    data-studio-tab-panel="source"
                    data-testid="studio-video-panel-source"
                    hidden
                >
                    {% include 'components/empty_state.html.twig' with {
                        title: 'Aucune source vidéo',
                        description: 'Ajoutez une source YouTube ou un fichier heberge pour rendre la video consultable.',
                        icon: 'video',
                    } %}
                    <div class="mt-4 flex justify-center">
                        {% include 'components/button.html.twig' with {
                            label: 'Ajouter une source',
                            variant: 'primary',
                            icon: 'plus',
                            disabled: true,
                        } %}
                    </div>
                </section>

                <section
                    id="panel-classification"
                    class="ds-tabs__panel"
                    role="tabpanel"
                    aria-labelledby="tab-classification"
                    data-studio-tab-panel="classification"
                    data-testid="studio-video-panel-classification"
                    hidden
                >
                    {% include 'components/empty_state.html.twig' with {
                        title: 'Aucun tag ni playlist',
                        description: 'Les tags et playlists permettront de classer la video dans le catalogue pedagogique.',
                        icon: 'tags',
                    } %}
                    <p class="mt-4 text-center ds-text-secondary ds-text-muted">
                        Selection des tags et rattachement aux playlists : bientot disponible.
                    </p>
                </section>

                {% include 'studio/partials/video_publication_panel.html.twig' with {
                    video: video,
                    publicationActions: publicationActions,
                } %}
            </div>
        </div>
    </div>
{% endblock %}
