{#
    Props:
    - status (PublicationStatus enum, optional)
    - content_form_id (optional - id du formulaire contenu pour le bouton Enregistrer)
    - testid (optional data-testid)
#}
<div
    class="ds-publish-action-bar"
    {% if testid is defined and testid %}data-testid="{{ testid }}"{% endif %}
>
    <div class="ds-page-actions">
        {% if status is defined and status %}
            <div class="ds-page-actions__status">
                {% include 'studio/partials/publication_status_badge.html.twig' with { status: status } %}
            </div>
        {% endif %}

        {% if content_form_id is defined and content_form_id %}
            {% include 'components/button.html.twig' with {
                label: 'Enregistrer',
                type: 'submit',
                variant: 'ghost',
                size: 'sm',
                icon: 'save',
                attrs: {
                    'form': content_form_id,
                    'data-testid': 'studio-video-save',
                },
            } %}
        {% else %}
            {% include 'components/button.html.twig' with {
                label: 'Enregistrer',
                variant: 'ghost',
                size: 'sm',
                icon: 'save',
                disabled: true,
                attrs: {
                    'aria-disabled': 'true',
                    'data-testid': 'studio-video-save',
                },
            } %}
        {% endif %}

        {% include 'components/publish_split_button.html.twig' with {
            primary_label: 'Publier maintenant',
            disabled: true,
            menu_id: 'studio-video-publish-menu',
            testid: 'studio-video-publish-split',
            primary_testid: 'studio-video-publish-now',
            menu_testid: 'studio-video-publish-options',
            items: [
                { label: 'Programmer', icon: 'calendar', disabled: true },
                { label: 'Remettre en brouillon', icon: 'undo-2', disabled: true },
                { label: 'Archiver', icon: 'archive', disabled: true },
            ],
        } %}
    </div>
</div>
