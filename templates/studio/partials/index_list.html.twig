{#
    Props:
    - items (iterable of Content|Playlist)
    - edit_route (optional Symfony route name for edit links)
#}
<div data-studio-index-list class="w-full">
    <ul class="space-y-3 lg:hidden" role="list" aria-label="Liste des contenus">
        {% for item in items %}
            {% set display_date = item.publishedAt ?? item.createdAt %}
            {% set edit_url = edit_route is defined and edit_route ? path(edit_route, { id: item.id }) : null %}
            <li class="ds-card p-4">
                <div class="flex flex-col gap-3">
                    <div class="flex items-start justify-between gap-3">
                        <h3 class="min-w-0 flex-1 text-base font-semibold">
                            {% if edit_url %}
                                <a href="{{ edit_url }}" class="ds-focus block truncate" title="{{ item.title }}">
                                    {{ item.title }}
                                </a>
                            {% else %}
                                <span class="block truncate" title="{{ item.title }}">{{ item.title }}</span>
                            {% endif %}
                        </h3>
                        <div class="shrink-0">
                            {% include 'studio/partials/publication_status_badge.html.twig' with { status: item.status } %}
                        </div>
                    </div>
                    <p class="ds-text-secondary ds-text-muted">
                        <time datetime="{{ display_date|date('c') }}">
                            {{ display_date|date('d/m/Y H:i') }}
                        </time>
                        <span class="ds-text-caption ds-text-subtle">
                            · {{ item.publishedAt ? 'Publié' : 'Créé' }}
                        </span>
                    </p>
                    {% if edit_url %}
                        <div>
                            {% include 'components/button.html.twig' with {
                                label: 'Modifier',
                                href: edit_url,
                                variant: 'secondary',
                                size: 'sm',
                                icon: 'pencil',
                            } %}
                        </div>
                    {% endif %}
                </div>
            </li>
        {% endfor %}
    </ul>

    <div data-studio-index-table class="hidden lg:block">
        <div class="ds-card overflow-hidden">
            <table class="ds-table">
                <thead class="ds-table-head">
                    <tr>
                        <th scope="col" class="px-5 py-3">Titre</th>
                        <th scope="col" class="px-5 py-3">Statut</th>
                        <th scope="col" class="px-5 py-3">Date</th>
                        {% if edit_route is defined and edit_route %}
                            <th scope="col" class="px-5 py-3"><span class="sr-only">Actions</span></th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody class="divide-y ds-table-divider">
                    {% for item in items %}
                        {% set display_date = item.publishedAt ?? item.createdAt %}
                        {% set edit_url = edit_route is defined and edit_route ? path(edit_route, { id: item.id }) : null %}
                        <tr class="ds-table-row">
                            <td class="max-w-xs px-5 py-4">
                                {% if edit_url %}
                                    <a href="{{ edit_url }}" class="ds-focus block truncate font-medium" title="{{ item.title }}">
                                        {{ item.title }}
                                    </a>
                                {% else %}
                                    <span class="block truncate font-medium" title="{{ item.title }}">
                                        {{ item.title }}
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-4">
                                {% include 'studio/partials/publication_status_badge.html.twig' with { status: item.status } %}
                            </td>
                            <td class="px-5 py-4 ds-text-muted">
                                <time datetime="{{ display_date|date('c') }}">
                                    {{ display_date|date('d/m/Y H:i') }}
                                </time>
                                {% if item.publishedAt %}
                                    <span class="block ds-text-caption ds-text-subtle">Publié</span>
                                {% else %}
                                    <span class="block ds-text-caption ds-text-subtle">Créé</span>
                                {% endif %}
                            </td>
                            {% if edit_url %}
                                <td class="px-5 py-4">
                                    <a href="{{ edit_url }}" class="ds-nav-link gap-1.5 px-3" data-studio-edit-link>
                                        {% include 'components/icon.html.twig' with { name: 'pencil', size: 14 } %}
                                        <span>Modifier</span>
                                    </a>
                                </td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
