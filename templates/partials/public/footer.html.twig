<footer class="ds-site-footer mt-20">
    <div class="ds-container py-14">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
            <div>
                <h2 class="ds-site-footer__title">Lazare Fortune</h2>
                <p class="mt-4 max-w-sm text-base leading-relaxed ds-text-muted">
                    Developpeur web FullStack passionne par la tech, la creation et le partage.
                </p>
                <ul class="mt-6 flex gap-4">
                    <li>
                        <a href="https://github.com/lazarefortune" target="_blank" rel="noopener noreferrer" class="ds-site-footer__social" aria-label="GitHub">
                            {% include 'components/icon.html.twig' with { name: 'github', size: 22 } %}
                        </a>
                    </li>
                    <li>
                        <a href="https://www.youtube.com/channel/UCITKwfT7qVXjdHHu84Atodw" target="_blank" rel="noopener noreferrer" class="ds-site-footer__social" aria-label="YouTube">
                            {% include 'components/icon.html.twig' with { name: 'youtube', size: 22 } %}
                        </a>
                    </li>
                    <li>
                        <a href="https://www.linkedin.com/in/lazare-fortune/" target="_blank" rel="noopener noreferrer" class="ds-site-footer__social" aria-label="LinkedIn">
                            {% include 'components/icon.html.twig' with { name: 'linkedin', size: 22 } %}
                        </a>
                    </li>
                    <li>
                        <a href="https://twitter.com/lazarefortune" target="_blank" rel="noopener noreferrer" class="ds-site-footer__social" aria-label="Twitter">
                            {% include 'components/icon.html.twig' with { name: 'twitter', size: 22 } %}
                        </a>
                    </li>
                </ul>
            </div>

            <div>
                <h2 class="ds-site-footer__title">Navigation</h2>
                <ul class="ds-site-footer__list mt-4">
                    <li>
                        <a href="{{ path('app_home') }}">
                            {% include 'components/icon.html.twig' with { name: 'home', size: 18 } %}
                            Accueil
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_design_system') }}">
                            {% include 'components/icon.html.twig' with { name: 'palette', size: 18 } %}
                            Design system
                        </a>
                    </li>
                    {% if app.user %}
                        <li>
                            <a href="{{ path('app_account') }}">
                                {% include 'components/icon.html.twig' with { name: 'user', size: 18 } %}
                                Mon compte
                            </a>
                        </li>
                    {% else %}
                        <li>
                            <a href="{{ path('app_login') }}">
                                {% include 'components/icon.html.twig' with { name: 'log-in', size: 18 } %}
                                Connexion
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>

            <div>
                <h2 class="ds-site-footer__title">Plateforme</h2>
                <ul class="ds-site-footer__list mt-4">
                    <li>
                        <a href="{{ path('app_design_system') }}">
                            {% include 'components/icon.html.twig' with { name: 'layout-dashboard', size: 18 } %}
                            Reference UI V3
                        </a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li>
                            <a href="{{ path('studio_home') }}">
                                {% include 'components/icon.html.twig' with { name: 'video', size: 18 } %}
                                Studio
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>

            <div>
                <h2 class="ds-site-footer__title">Contact</h2>
                <ul class="ds-site-footer__list mt-4">
                    <li>
                        <a href="mailto:lazarefortune@gmail.com">
                            {% include 'components/icon.html.twig' with { name: 'mail', size: 18 } %}
                            lazarefortune@gmail.com
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="mt-12 ds-border-t pt-6 text-center text-sm ds-text-muted">
            &copy; {{ 'now'|date('Y') }} Lazare Fortune. Tous droits reserves.
        </div>
    </div>
</footer>
