<header class="ds-site-header sticky top-0 z-40">
    <div class="ds-container flex min-h-[4.5rem] items-center justify-between gap-4 py-4">
        <div class="flex min-w-0 items-center gap-2 md:gap-6">
            <a href="{{ path('app_home') }}" class="ds-brand-link shrink-0">
                {% include 'components/icon.html.twig' with { name: 'play-circle', size: 28, class: 'text-[var(--ds-primary)]' } %}
                <span class="hidden text-base font-semibold tracking-tight sm:inline">{{ app_name }}</span>
            </a>

            <nav aria-label="Navigation principale" class="hidden items-center gap-1 md:flex">
                <a href="{{ path('app_home') }}" class="ds-nav-link">
                    {% include 'components/icon.html.twig' with { name: 'home', size: 16 } %}
                    <span>Accueil</span>
                </a>
                <a href="{{ path('app_design_system') }}" class="ds-nav-link">
                    {% include 'components/icon.html.twig' with { name: 'palette', size: 16 } %}
                    <span>Design system</span>
                </a>
            </nav>
        </div>

        <div class="flex shrink-0 items-center gap-1 sm:gap-2">
            {% include 'components/theme_toggle.html.twig' %}
            {% if app.user %}
                <a href="{{ path('app_account') }}" class="ds-nav-link">
                    {% include 'components/icon.html.twig' with { name: 'user', size: 16 } %}
                    <span class="hidden sm:inline">Mon compte</span>
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('studio_home') }}" class="ds-nav-link">
                        {% include 'components/icon.html.twig' with { name: 'layout-dashboard', size: 16 } %}
                        <span class="hidden sm:inline">Studio</span>
                    </a>
                {% endif %}
            {% else %}
                <a href="{{ path('app_register') }}" class="ds-nav-link hidden sm:inline-flex">
                    {% include 'components/icon.html.twig' with { name: 'user-plus', size: 16 } %}
                    <span>Inscription</span>
                </a>
                <a href="{{ path('app_login') }}" class="ds-nav-link">
                    {% include 'components/icon.html.twig' with { name: 'log-in', size: 16 } %}
                    <span class="hidden sm:inline">Connexion</span>
                </a>
            {% endif %}
        </div>
    </div>
</header>
