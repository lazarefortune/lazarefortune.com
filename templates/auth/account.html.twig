{% extends 'base.html.twig' %}

{% block title %}Mon compte - lazarefortune.com{% endblock %}

{% block main %}
    <section class="ds-section">
        <div class="ds-container-narrow mx-auto flex max-w-md flex-col gap-6 py-8 sm:py-16">
            {% include 'components/page_header.html.twig' with {
                title: 'Mon compte',
                description: 'Informations de votre compte.',
            } %}

            <dl class="ds-card divide-y divide-slate-100">
                <div class="px-5 py-3">
                    <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">E-mail</dt>
                    <dd class="mt-1 text-sm text-slate-900">{{ user.email }}</dd>
                </div>
                {% if user.fullname %}
                    <div class="px-5 py-3">
                        <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Nom</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ user.fullname }}</dd>
                    </div>
                {% endif %}
                <div class="px-5 py-3">
                    <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Rôles</dt>
                    <dd class="mt-1 text-sm text-slate-900">{{ user.roles|join(', ') }}</dd>
                </div>
            </dl>

            <div class="flex flex-wrap gap-3">
                {% if is_granted('ROLE_ADMIN') %}
                    {% include 'components/button.html.twig' with {
                        label: 'Ouvrir le Studio',
                        href: path('studio_home'),
                        variant: 'primary',
                    } %}
                {% endif %}
                {% include 'components/button.html.twig' with {
                    label: 'Accueil',
                    href: path('app_home'),
                    variant: 'secondary',
                } %}
                {% include 'components/button.html.twig' with {
                    label: 'Déconnexion',
                    href: path('app_logout'),
                    variant: 'ghost',
                } %}
            </div>
        </div>
    </section>
{% endblock %}
