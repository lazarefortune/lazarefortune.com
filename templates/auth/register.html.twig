{% extends 'base.html.twig' %}

{% block title %}Inscription - lazarefortune.com{% endblock %}

{% block main %}
    <section class="ds-section">
        <div class="ds-container-narrow mx-auto flex max-w-md flex-col justify-center gap-6 py-8 sm:min-h-[60vh] sm:py-16">
            {% include 'components/page_header.html.twig' with {
                title: 'Créer un compte',
                description: 'Rejoignez lazarefortune.com.',
            } %}

            {% for message in app.flashes('error') %}
                {% include 'components/alert.html.twig' with { variant: 'danger', message: message } %}
            {% endfor %}

            {{ form_start(registrationForm, { attr: { class: 'flex flex-col gap-4' } }) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.fullname) }}
                {{ form_row(registrationForm.plainPassword.first) }}
                {{ form_row(registrationForm.plainPassword.second) }}

                {% include 'components/button.html.twig' with { label: "S'inscrire", type: 'submit', variant: 'primary' } %}
            {{ form_end(registrationForm) }}

            <p class="text-center text-sm text-slate-600">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" class="font-medium text-primary-600 hover:text-primary-700">Se connecter</a>
            </p>
        </div>
    </section>
{% endblock %}
