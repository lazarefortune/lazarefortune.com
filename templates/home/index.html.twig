{% extends 'layouts/base-home.html.twig' %}

{% block title %}Lazare Fortune{% endblock %}

{% block body %}
    <!-- Header -->
    {% include 'blocs/_header.html.twig' %}

    <!--==================== MAIN ====================-->
    <main class="main">
        <!--==================== HOME ====================-->
        {{ include('partials/home/home.html.twig') }}

        <!--==================== ABOUT ====================-->
        {{ include('partials/home/about.html.twig') }}

        <!--==================== SKILLS ====================-->
        {{ include('partials/home/skills.html.twig') }}

        <!--==================== QUALIFICATION ====================-->
        {{ include('partials/home/qualification.html.twig') }}

        <!--==================== SERVICES ====================-->
        {{ include('partials/home/services.html.twig') }}

        <!--==================== PORTFOLIO ====================-->
        {{ include('partials/home/portfolio.html.twig') }}

        <!--==================== Hobbies ====================-->
        {{ include('partials/home/hobbies.html.twig') }}

        <!--==================== PROJECT IN MIND ====================-->
        <!-- <section class="project section">

        </section> -->

        <!--==================== TESTIMONIAL ====================-->
        <!-- <section class="testimonial section">

        </section> -->

        <!--==================== CONTACT ME ====================-->
        <section class="contact section" id="contact">
            <h2 class="section__title">Me contacter</h2>
            <span class="section__subtitle">Vous pouvez utiliser le formulaire ci-dessous pour me contacter</span>

            <div class="contact__container container grid">
                <div>
                    <div class="contact__information">
                        <i class="uil uil-envelope contact__icon"></i>

                        <a href="mailto:lazarefortune@gmail.com">
                            <h3 class="contact__title">Email</h3>
                            <span class="contact__subtitle">lazarefortune@gmail.com</span>
                        </a>
                    </div>

                    <div class="contact__information">
                        <i class="uil uil-map-marker contact__icon"></i>

                        <div>
                            <h3 class="contact__title">Localisation</h3>
                            <span class="contact__subtitle">Villiers-sur-marne</span>
                        </div>
                    </div>
                </div>
                {{ form_start(formContact) }}
                <div class="contact__form grid">
                    {% include 'layouts/messages/custom-flash-messages.html.twig' %}
                    <div class="contact__inputs grid">
                        <div class="contact__content">
                            <label for="name" class="contact__label">Nom</label>
                            {{ form_widget(formContact.name) }}
                        </div>
                        <div class="contact__content">
                            <label for="email" class="contact__label">Email</label>
                            {{ form_widget(formContact.email) }}
                        </div>
                    </div>
                    <div class="contact__content">
                        <label for="object" class="contact__label">Objet du message</label>
                        {{ form_widget(formContact.subject) }}
                    </div>
                    <div class="contact__content">
                        <label for="message" class="contact__label">Entrez votre message</label>
                        {{ form_widget(formContact.message) }}
                    </div>
                    <div>
                        <button type="submit" name="formSubmit" class="button button--flex contact__submit">
                            Envoyer le message
                            <i class="uil uil-message button__icon"></i>
                        </button>
                    </div>
                </div>
                    {{ form_end(formContact) }}
            </div>
        </section>
    </main>

    <!--==================== FOOTER ====================-->
    {{ include('blocs/_footer.html.twig') }}

    <!--==================== SCROLL TOP ====================-->
    <a href="#" class="scrollup" id="scroll-up">
        <i class="uil uil-arrow-up scrollup__icon"></i>
    </a>

    <!-- MAIN JS -->
    <script src="{{ asset('assets/js/script.js') }}"></script>
{% endblock %}
