{% extends 'base.html.twig' %}

{% block title %}Design system - lazarefortune.com{% endblock %}

{% block main %}
    <section class="ds-section">
        <div class="ds-container" data-testid="design-system-page">
            {% embed 'components/page_header.html.twig' with {
                eyebrow: 'Reference UI',
                title: 'Design system V3',
                description: 'Page de test permanente pour valider tokens, composants et themes light/dark.',
            } %}
                {% block page_header_actions %}
                    {% include 'components/theme_toggle.html.twig' %}
                {% endblock %}
            {% endembed %}

            <section class="mb-10" data-testid="design-system-tokens" aria-labelledby="tokens-heading">
                <h2 id="tokens-heading" class="mb-4 text-lg font-semibold">Couleurs / tokens</h2>
                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                    {% for token in [
                        { name: 'bg', var: '--ds-bg' },
                        { name: 'surface', var: '--ds-surface' },
                        { name: 'surface-soft', var: '--ds-surface-soft' },
                        { name: 'text', var: '--ds-text' },
                        { name: 'text-muted', var: '--ds-text-muted' },
                        { name: 'border', var: '--ds-border' },
                        { name: 'primary', var: '--ds-primary' },
                        { name: 'primary-soft', var: '--ds-primary-soft' },
                        { name: 'secondary', var: '--ds-secondary' },
                        { name: 'success', var: '--ds-success' },
                        { name: 'warning', var: '--ds-warning' },
                        { name: 'danger', var: '--ds-danger' },
                    ] %}
                        <div class="ds-token-swatch">
                            <span class="ds-token-swatch__color" style="background: var({{ token.var }})"></span>
                            <div>
                                <p class="font-medium">{{ token.name }}</p>
                                <p class="ds-text-caption ds-text-muted">{{ token.var }}</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-typography" aria-labelledby="typography-heading">
                <h2 id="typography-heading" class="mb-4 text-lg font-semibold">Typographie</h2>
                <div class="ds-card px-5 py-4">
                    <p class="text-base">Texte principal 16px - Inter</p>
                    <p class="mt-2 ds-text-secondary ds-text-muted">Texte secondaire 14px</p>
                    <p class="mt-2 ds-text-caption ds-text-muted">Caption 12px - breadcrumb, badges, hints</p>
                    <h3 class="ds-heading mt-4 text-xl font-semibold">Titre display - Space Grotesk</h3>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-buttons" aria-labelledby="buttons-heading">
                <h2 id="buttons-heading" class="mb-4 text-lg font-semibold">Buttons</h2>
                <p class="mb-3 ds-text-secondary ds-text-muted">Variantes</p>
                <div class="flex flex-wrap gap-2">
                    {% include 'components/button.html.twig' with { label: 'Primary', variant: 'primary', icon: 'plus' } %}
                    {% include 'components/button.html.twig' with { label: 'Secondary', variant: 'secondary' } %}
                    {% include 'components/button.html.twig' with { label: 'Ghost', variant: 'ghost' } %}
                    {% include 'components/button.html.twig' with { label: 'Danger', variant: 'danger', icon: 'trash-2' } %}
                    {% include 'components/button.html.twig' with { label: 'Disabled', variant: 'primary', disabled: true } %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-button-sizes" aria-labelledby="button-sizes-heading">
                <h2 id="button-sizes-heading" class="mb-4 text-lg font-semibold">Tailles de boutons</h2>
                <div class="flex flex-wrap items-end gap-3">
                    {% include 'components/button.html.twig' with { label: 'Small', variant: 'primary', size: 'sm' } %}
                    {% include 'components/button.html.twig' with { label: 'Medium', variant: 'primary', size: 'md' } %}
                    {% include 'components/button.html.twig' with { label: 'Large', variant: 'primary', size: 'lg' } %}
                </div>
                <div class="mt-4 flex flex-wrap items-end gap-3">
                    {% include 'components/button.html.twig' with { label: 'Small', variant: 'secondary', size: 'sm' } %}
                    {% include 'components/button.html.twig' with { label: 'Medium', variant: 'secondary', size: 'md' } %}
                    {% include 'components/button.html.twig' with { label: 'Large', variant: 'secondary', size: 'lg' } %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-forms" aria-labelledby="forms-heading">
                <h2 id="forms-heading" class="mb-4 text-lg font-semibold">Forms</h2>
                <div class="grid max-w-xl gap-4">
                    <div>
                        <label class="ds-label" for="ds-form-input">Label</label>
                        <input id="ds-form-input" type="text" class="ds-input" placeholder="Input texte">
                        <p class="ds-form-help">Help text secondaire</p>
                    </div>
                    <div>
                        <label class="ds-label" for="ds-form-textarea">Textarea</label>
                        <textarea id="ds-form-textarea" class="ds-input min-h-24" rows="4" placeholder="Zone de texte"></textarea>
                    </div>
                    <div>
                        <label class="ds-label" for="ds-form-select">Select</label>
                        <select id="ds-form-select" class="ds-input">
                            <option>Option A</option>
                            <option>Option B</option>
                            <option>Option C</option>
                        </select>
                    </div>
                    <div>
                        <label class="ds-label" for="ds-form-error">Erreur</label>
                        <input id="ds-form-error" type="text" class="ds-input ds-input--error" value="Valeur invalide">
                        <p class="ds-form-error">Ce champ est obligatoire.</p>
                    </div>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-cards" aria-labelledby="cards-heading">
                <h2 id="cards-heading" class="mb-4 text-lg font-semibold">Cards</h2>
                <div class="grid gap-4 lg:grid-cols-2">
                    {% include 'components/card.html.twig' with {
                        title: 'Card public',
                        content: 'Surface blanche, bordure, ombre douce et coins arrondis.',
                        footer: 'Footer secondaire',
                    } %}
                    <article class="ds-card ds-studio px-5 py-4">
                        <h3 class="text-base font-semibold">Card Studio</h3>
                        <p class="mt-2 ds-text-muted">Meme tokens, contexte dashboard.</p>
                    </article>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-badges" aria-labelledby="badges-heading">
                <h2 id="badges-heading" class="mb-4 text-lg font-semibold">Badges</h2>
                <p class="mb-3 ds-text-secondary ds-text-muted">Variantes (taille md par defaut)</p>
                <div class="flex flex-wrap gap-2">
                    {% include 'components/badge.html.twig' with { label: 'Default' } %}
                    {% include 'components/badge.html.twig' with { label: 'Primary', variant: 'primary' } %}
                    {% include 'components/badge.html.twig' with { label: 'Brouillon' } %}
                    {% include 'components/badge.html.twig' with { label: 'Planifie', variant: 'warning' } %}
                    {% include 'components/badge.html.twig' with { label: 'Publie', variant: 'success' } %}
                    {% include 'components/badge.html.twig' with { label: 'Archive' } %}
                    {% include 'components/badge.html.twig' with { label: 'Info', variant: 'info' } %}
                    {% include 'components/badge.html.twig' with { label: 'Danger', variant: 'danger' } %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-badge-sizes" aria-labelledby="badge-sizes-heading">
                <h2 id="badge-sizes-heading" class="mb-4 text-lg font-semibold">Tailles de badges</h2>
                <div class="flex flex-wrap items-center gap-3">
                    {% include 'components/badge.html.twig' with { label: 'Small', variant: 'primary', size: 'sm' } %}
                    {% include 'components/badge.html.twig' with { label: 'Medium', variant: 'primary', size: 'md' } %}
                    {% include 'components/badge.html.twig' with { label: 'Large', variant: 'primary', size: 'lg' } %}
                </div>
                <div class="mt-4 flex flex-wrap items-center gap-3">
                    {% include 'components/badge.html.twig' with { label: 'Small', variant: 'success', size: 'sm' } %}
                    {% include 'components/badge.html.twig' with { label: 'Medium', variant: 'success', size: 'md' } %}
                    {% include 'components/badge.html.twig' with { label: 'Large', variant: 'success', size: 'lg' } %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-alerts" aria-labelledby="alerts-heading">
                <h2 id="alerts-heading" class="mb-4 text-lg font-semibold">Alerts</h2>
                <div class="grid max-w-3xl gap-3">
                    {% include 'components/alert.html.twig' with { variant: 'success', message: 'Operation reussie.' } %}
                    {% include 'components/alert.html.twig' with { variant: 'info', message: 'Information utile pour guider l utilisateur.' } %}
                    {% include 'components/alert.html.twig' with { variant: 'warning', message: 'Attention: verifiez les champs avant de continuer.' } %}
                    {% include 'components/alert.html.twig' with { variant: 'danger', message: 'Une erreur bloquante est survenue.' } %}
                    {% include 'components/alert.html.twig' with {
                        variant: 'info',
                        message: 'Alert dismissible avec timer (5 secondes). Survolez pour mettre en pause.',
                        dismissible: true,
                        flash_item: true,
                        flash_type: 'info',
                        auto_dismiss: true,
                    } %}
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-flash" aria-labelledby="flash-heading">
                <h2 id="flash-heading" class="mb-4 text-lg font-semibold">Flash messages</h2>
                <div class="grid max-w-3xl gap-4">
                    <div>
                        <p class="mb-2 ds-text-secondary font-medium">Inline</p>
                        <div data-flash-messages data-flash-mode="inline" class="ds-flash-inline">
                            {% include 'components/alert.html.twig' with {
                                variant: 'success',
                                message: 'Flash inline - reste dans le flux.',
                                flash_item: true,
                                flash_type: 'success',
                                class: 'mb-0',
                            } %}
                        </div>
                    </div>
                    <div>
                        <p class="mb-2 ds-text-secondary font-medium">Floating preview</p>
                        <div class="relative min-h-44 rounded-lg border border-dashed ds-border-dashed p-4">
                            <div data-flash-messages data-flash-mode="floating" class="ds-flash-floating !relative !left-0 !right-0 !top-0 !max-w-none sm:!max-w-md">
                                {% include 'components/alert.html.twig' with {
                                    variant: 'success',
                                    message: 'Success auto-dismiss 5s avec barre de progression.',
                                    dismissible: true,
                                    flash_item: true,
                                    flash_type: 'success',
                                    auto_dismiss: true,
                                    class: 'ds-flash-item mb-3',
                                } %}
                                {% include 'components/alert.html.twig' with {
                                    variant: 'danger',
                                    message: 'Danger persistent (pas de timer).',
                                    dismissible: true,
                                    flash_item: true,
                                    flash_type: 'danger',
                                    class: 'ds-flash-item mb-0',
                                } %}
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-toast" aria-labelledby="toast-heading">
                <h2 id="toast-heading" class="mb-4 text-lg font-semibold">Toast</h2>
                <div class="ds-card px-5 py-4">
                    <p class="ds-text-muted">Toasts en bas a droite. Les variantes success et info incluent un timer de 5 secondes avec barre visible.</p>
                    <div class="mt-4">
                        <p class="mb-2 ds-text-secondary font-medium">Avec timer (auto-dismiss)</p>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="ds-btn ds-btn-md ds-btn-primary" data-toast-trigger="success" data-toast-timer="true">Toast success</button>
                            <button type="button" class="ds-btn ds-btn-md ds-btn-secondary" data-toast-trigger="info" data-toast-timer="true">Toast info</button>
                            <button type="button" class="ds-btn ds-btn-md ds-btn-secondary" data-toast-trigger="warning" data-toast-timer="true">Toast warning</button>
                        </div>
                    </div>
                    <div class="mt-4">
                        <p class="mb-2 ds-text-secondary font-medium">Persistants (sans timer)</p>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="ds-btn ds-btn-md ds-btn-danger" data-toast-trigger="danger">Toast danger</button>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-tables" aria-labelledby="tables-heading">
                <h2 id="tables-heading" class="mb-4 text-lg font-semibold">Tables</h2>
                <div class="ds-card overflow-hidden">
                    <table class="ds-table">
                        <thead class="ds-table-head">
                            <tr>
                                <th>Titre</th>
                                <th>Statut</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="ds-table-row">
                                <td>Introduction Symfony</td>
                                <td>{% include 'components/badge.html.twig' with { label: 'Publie', variant: 'success' } %}</td>
                                <td>07/06/2026</td>
                            </tr>
                            <tr class="ds-table-row">
                                <td>Routing avance</td>
                                <td>{% include 'components/badge.html.twig' with { label: 'Brouillon' } %}</td>
                                <td>06/06/2026</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-breadcrumb" aria-labelledby="breadcrumb-heading">
                <h2 id="breadcrumb-heading" class="mb-4 text-lg font-semibold">Breadcrumb</h2>
                <nav aria-label="Exemple breadcrumb public" class="ds-breadcrumb mb-4">
                    <ol class="flex flex-wrap items-center gap-1 sm:gap-1.5">
                        <li class="flex items-center gap-1">
                            <a href="#" class="ds-breadcrumb__link"><span>Accueil</span></a>
                        </li>
                        <li class="flex items-center gap-1">
                            <span class="ds-breadcrumb__separator">/</span>
                            <span class="ds-breadcrumb__current"><span>Page courante</span></span>
                        </li>
                    </ol>
                </nav>
                <nav aria-label="Exemple breadcrumb Studio" class="ds-breadcrumb">
                    <ol class="flex flex-wrap items-center gap-1 sm:gap-1.5">
                        <li class="flex items-center gap-1">
                            <a href="#" class="ds-breadcrumb__link">
                                {% include 'components/icon.html.twig' with { name: 'layout-dashboard', size: 14 } %}
                                <span>Dashboard</span>
                            </a>
                        </li>
                        <li class="flex items-center gap-1">
                            <span class="ds-breadcrumb__separator">/</span>
                            <span class="ds-breadcrumb__current">
                                {% include 'components/icon.html.twig' with { name: 'video', size: 14 } %}
                                <span>Videos</span>
                            </span>
                        </li>
                    </ol>
                </nav>
            </section>

            <section class="mb-10" data-testid="design-system-split-button" aria-labelledby="split-button-heading">
                <h2 id="split-button-heading" class="mb-4 text-lg font-semibold">Publish split button</h2>
                <p class="mb-4 ds-text-secondary ds-text-muted">
                    Composant dedie a la publication Studio : un seul bloc primary avec action principale et chevron integres.
                </p>

                <div class="mb-6 grid max-w-3xl gap-4">
                    <div>
                        <p class="mb-2 text-sm font-medium">Actif</p>
                        <div class="ds-card px-5 py-4">
                            {% include 'components/publish_split_button.html.twig' with {
                                primary_label: 'Publier maintenant',
                                menu_id: 'design-system-publish-menu-active',
                                testid: 'design-system-publish-split-active',
                                items: [
                                    { label: 'Programmer', icon: 'calendar' },
                                    { label: 'Remettre en brouillon', icon: 'undo-2' },
                                    { label: 'Archiver', icon: 'archive' },
                                ],
                            } %}
                        </div>
                    </div>

                    <div>
                        <p class="mb-2 text-sm font-medium">Desactive (action principale indisponible)</p>
                        <div class="ds-card px-5 py-4">
                            {% include 'components/publish_split_button.html.twig' with {
                                primary_label: 'Publier maintenant',
                                disabled: true,
                                menu_id: 'design-system-publish-menu-disabled',
                                testid: 'design-system-publish-split-disabled',
                                items: [
                                    { label: 'Programmer', icon: 'calendar', disabled: true },
                                    { label: 'Remettre en brouillon', icon: 'undo-2', disabled: true },
                                    { label: 'Archiver', icon: 'archive', disabled: true },
                                ],
                            } %}
                        </div>
                    </div>
                </div>

                <div class="mb-6">
                    <p class="mb-2 text-sm font-medium">Barre d actions complete (page edition)</p>
                    <div class="ds-card max-w-3xl px-5 py-4">
                        {% include 'studio/partials/publish_action_bar.html.twig' with {
                            testid: 'design-system-publish-action-bar',
                        } %}
                    </div>
                </div>

                <div>
                    <p class="mb-2 text-sm font-medium">Menu ouvert (demo statique)</p>
                    <div class="ds-card max-w-3xl px-5 py-4">
                        {% include 'components/publish_split_button.html.twig' with {
                            primary_label: 'Publier maintenant',
                            menu_id: 'design-system-publish-menu-open',
                            menu_open: true,
                            testid: 'design-system-publish-split-open',
                            items: [
                                { label: 'Programmer', icon: 'calendar' },
                                { label: 'Remettre en brouillon', icon: 'undo-2' },
                                { label: 'Archiver', icon: 'archive' },
                            ],
                        } %}
                    </div>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-empty-states" aria-labelledby="empty-heading">
                <h2 id="empty-heading" class="mb-4 text-lg font-semibold">Empty states</h2>
                {% include 'components/empty_state.html.twig' with {
                    title: 'Aucune video',
                    description: 'Commencez par creer votre premiere video pedagogique.',
                    action_label: 'Creer une video',
                    action_href: '#',
                    icon: 'video',
                } %}
            </section>

            <section class="mb-10" data-testid="design-system-studio-preview" aria-labelledby="studio-preview-heading">
                <h2 id="studio-preview-heading" class="mb-4 text-lg font-semibold">Studio layout</h2>
                <p class="mb-4 text-sm ds-text-muted">Preview du shell Studio legacy : sidebar 300px, header fixe, zone main scrollable.</p>
                <div class="overflow-hidden rounded-2xl border ds-border bg-[var(--ds-studio-bg)]" data-testid="design-system-studio-layout-preview">
                    <div class="relative flex min-h-[22rem]">
                        <div class="hidden w-[300px] shrink-0 flex-col gap-4 border-r ds-border bg-[var(--ds-studio-surface)] p-5 lg:flex">
                            <div class="flex items-center gap-2">
                                <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--ds-primary)] text-sm font-bold text-white">LF</span>
                                <span class="text-2xl font-bold">Studio</span>
                            </div>
                            <ul class="space-y-1" role="list">
                                <li><div class="rounded-full px-6 py-2 text-base font-medium text-[var(--ds-studio-nav-active-text)] bg-[var(--ds-studio-nav-active-bg)]">Vidéos</div></li>
                                <li><div class="rounded-full px-6 py-2 text-base ds-text-muted">Articles</div></li>
                                <li><div class="rounded-full px-6 py-2 text-base ds-text-muted">Playlists</div></li>
                            </ul>
                            <div class="mt-auto border-t ds-border pt-4">
                                <div class="rounded-full px-6 py-2 text-base ds-text-muted">Quitter le studio</div>
                            </div>
                        </div>
                        <div class="flex min-w-0 flex-1 flex-col">
                            <div class="flex h-20 items-center justify-between border-b ds-border bg-[var(--ds-studio-surface)] px-4 shadow-sm lg:pl-4">
                                <div class="inline-flex h-11 w-11 items-center justify-center rounded-md border ds-border lg:hidden" aria-hidden="true">
                                    <span class="text-xs font-semibold">Menu</span>
                                </div>
                                <div class="ml-auto flex items-center gap-2">
                                    <div class="inline-flex h-10 w-10 items-center justify-center rounded-full border ds-border text-xs">Theme</div>
                                    <div class="inline-flex h-11 w-11 items-center justify-center rounded-full border ds-border bg-[var(--ds-primary-soft)] text-sm font-bold text-[var(--ds-primary)]">LF</div>
                                </div>
                            </div>
                            <div class="flex-1 p-4 lg:px-8">
                                <p class="text-xs font-semibold uppercase tracking-wide text-[var(--ds-primary)]">Studio</p>
                                <h3 class="mt-1 text-lg font-semibold">Zone contenu</h3>
                                <p class="mt-2 text-sm ds-text-muted">Breadcrumb, titres de page et modules React vivent ici.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="mb-10" data-testid="design-system-theme" aria-labelledby="theme-heading">
                <h2 id="theme-heading" class="mb-4 text-lg font-semibold">Theme toggle</h2>
                <div class="ds-card px-5 py-4">
                    {% include 'components/theme_toggle.html.twig' %}
                    <p class="mt-3 text-sm ds-text-muted">
                        Theme actif : <code class="ds-code" data-testid="active-theme-label">light</code>
                    </p>
                </div>
            </section>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('studio') }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var label = document.querySelector('[data-testid="active-theme-label"]');
            if (label) {
                var syncThemeLabel = function () {
                    label.textContent = document.documentElement.getAttribute('data-theme') || 'light';
                };
                syncThemeLabel();
                document.querySelectorAll('[data-theme-toggle]').forEach(function (button) {
                    button.addEventListener('click', function () {
                        window.setTimeout(syncThemeLabel, 0);
                    });
                });
            }

            document.querySelectorAll('[data-toast-trigger]').forEach(function (button) {
                button.addEventListener('click', function () {
                    if (typeof window.dsShowToast !== 'function') {
                        return;
                    }
                    var variant = button.getAttribute('data-toast-trigger') || 'info';
                    var autoDismiss = button.getAttribute('data-toast-timer') === 'true';
                    var message = autoDismiss
                        ? 'Toast ' + variant + ' avec timer de 5 secondes. Survolez pour mettre en pause.'
                        : 'Toast ' + variant + ' persistant.';
                    window.dsShowToast(message, variant, autoDismiss);
                });
            });
        });
    </script>
{% endblock %}
