{% extends 'base.html.twig' %}

{% block title %}Accueil - lazarefortune.com{% endblock %}

{% block main %}
    <section class="ds-section">
        <div class="ds-container-narrow flex flex-col gap-6 py-8 sm:py-16">
            {% include 'components/page_header.html.twig' with {
                eyebrow: 'V3 clean rebuild',
                title: 'lazarefortune.com',
                description: 'Plateforme vidéo personnelle en reconstruction. Le site public et le Studio seront réimplémentés progressivement.',
            } %}

            <div class="flex flex-wrap gap-3">
                {% if is_granted('ROLE_ADMIN') %}
                    {% include 'components/button.html.twig' with {
                        label: 'Ouvrir le Studio',
                        href: path('studio_home'),
                        variant: 'primary',
                    } %}
                {% endif %}
                {% if app.user %}
                    {% include 'components/button.html.twig' with {
                        label: 'Mon compte',
                        href: path('app_account'),
                        variant: 'secondary',
                    } %}
                {% else %}
                    {% include 'components/button.html.twig' with {
                        label: 'Connexion',
                        href: path('app_login'),
                        variant: 'secondary',
                    } %}
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
